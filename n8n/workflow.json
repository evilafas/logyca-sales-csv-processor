{
  "name": "LOGYCA - Daily Sales Summary",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every 5 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "url": "http://api:8000/jobs/completed",
        "options": {}
      },
      "id": "check-completed-jobs",
      "name": "Check Completed Jobs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/summary/calculate",
        "options": {}
      },
      "id": "calculate-summary",
      "name": "Calculate Daily Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 300]
    }
  ],
  "connections": {
    "Every 5 Minutes": {
      "main": [
        [
          {
            "node": "Check Completed Jobs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Completed Jobs": {
      "main": [
        [
          {
            "node": "Calculate Daily Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "logyca"
    }
  ]
}
